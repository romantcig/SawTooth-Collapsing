# Sawtooth Proxy Configuration File
# All fields have built-in defaults; only override what you need to change.

server:
  # Listen port, default: 9099 (optional)
  port: 9099
  # Listen host, default: localhost (optional)
  host: localhost

proxy:
  # Anthropic API target URL, default: https://api.anthropic.com (optional)
  target: https://api.anthropic.com
  # Usage deflation coefficient (0.0-1.0), default: 0.7 (optional)
  deflation: 0.7

debug:
  # Whether to enable structured debug facts, default: false (optional)
  enabled: false
  # Whether to additionally save complete raw inbound, forwarded, and response bodies.
  # This may contain sensitive prompts and tool results; default: false (optional)
  full_body: false
  # Directory to save debug data, default: ./data/ (optional)
  data_dir: ./data/

stubify:
  # Total token threshold to trigger deflation, default: 100000 (optional)
  token_threshold: 200000
  # Number of recent messages to keep un-stubified at the tail, default: 8 (optional)
  keep_recent: 8
  # Whether to keep thinking blocks, default: false (optional)
  # The reasoning process in thinking blocks might be valuable for context continuity, but the goal of sawtooth collapsing is to extract results rather than the process itself.
  keep_thinking: false

collapse:
  # Whether to enable collapsing, default: true (optional)
  enabled: true
  # [DEPRECATED] No longer read in Phase F collapse-first architecture.
  # Collapse is directly determined by the token budget logic in CalcCollapseCutoff, threshold * multiplier is no longer used.
  # This key is kept to prevent errors with old config files, but does not affect behavior.
  threshold_multiplier: 1.5

frozen:
  # Whether to enable frozen prefix, default: true (optional)
  enabled: true
  # Legacy compatibility value; effective Frozen TTL follows cache.cache_ttl
  ttl_minutes: 30

cache:
  # Whether to enable cache_control management, default: true (optional)
  enabled: true
  # Maximum cache_control breakpoints (Anthropic hard limit is 4)
  breakpoint_limit: 4
  # Cache TTL policy: "ephemeral" (default 5m) or "1h"
  # Affects Frozen TTL and the adaptive derivation of SawtoothTrigger pause thresholds
  cache_ttl: "ephemeral"
